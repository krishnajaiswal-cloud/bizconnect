rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection - only users can access their own document
    match /users/{uid} {
      allow read, write: if request.auth.uid == uid;
    }

    // Analyses collection - users can read/write their own analyses
    match /analyses/{id} {
      allow read, write: if request.auth.uid == resource.data.userId;
      allow create: if request.auth != null;
    }

    // Suppliers collection - everyone can read, only admins can write
    match /suppliers/{id} {
      allow read: if true;
      allow write: if false;
    }

    // Market data collection - everyone can read, only admins can write
    match /marketData/{id} {
      allow read: if true;
      allow write: if false;
    }
  }
}
